{
  "name": "@oeltkit/mcp",
  "version": "0.1.0",
  "description": "OELT MCP server — wraps the CLI and filesystem operations as tools for LLM authoring clients.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "oelt-mcp": "./dist/esm/index.js"
  },
  "main": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.conformance.json",
    "build:mcpb": "node scripts/build-mcpb.mjs",
    "conformance": "node dist/conformance/run.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@oeltkit/cli": "^0.1.0"
  }
}
