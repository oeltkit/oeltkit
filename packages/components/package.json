{
  "name": "@oeltkit/components",
  "version": "0.1.0",
  "description": "OELT interaction components — accessible, themeable, auto-tracked custom elements (<oelt-*>).",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:bundle": "esbuild src/index.ts --bundle --format=iife --global-name=oeltComponents --minify --sourcemap --outfile=dist/oelt.min.js",
    "build": "npm run build:esm && npm run build:bundle",
    "clean": "rm -rf dist"
  }
}
