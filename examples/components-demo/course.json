{
  "oelt": "0.1",
  "id": "org.oeltkit.components-demo",
  "title": "Components Demo",
  "lang": "en",
  "targets": ["scorm12", "scorm2004", "cmi5", "web"],
  "structure": [
    {
      "id": "m1",
      "title": "Components",
      "pages": [
        {
          "id": "p-mcq",
          "title": "Multiple choice",
          "src": "pages/mcq.html",
          "interactions": [{ "id": "mcq1", "type": "choice", "required": true }]
        },
        {
          "id": "p-branching",
          "title": "Branching scenario",
          "src": "pages/branching.html",
          "interactions": [{ "id": "scenario1", "type": "sequencing" }]
        },
        {
          "id": "p-media",
          "title": "Media",
          "src": "pages/media.html",
          "interactions": [{ "id": "media1", "type": "media" }]
        },
        {
          "id": "p-text",
          "title": "Short answer",
          "src": "pages/text-entry.html",
          "interactions": [{ "id": "te1", "type": "fill-in" }]
        },
        {
          "id": "p-quiz",
          "title": "Quiz",
          "src": "pages/quiz.html",
          "interactions": [{ "id": "quizfinal", "type": "performance", "required": true }]
        },
        {
          "id": "p-survey",
          "title": "Survey",
          "src": "pages/likert.html",
          "interactions": [{ "id": "survey1", "type": "likert" }]
        },
        {
          "id": "p-ordering",
          "title": "Ordering",
          "src": "pages/ordering.html",
          "interactions": [{ "id": "order1", "type": "sequencing" }]
        },
        {
          "id": "p-matching",
          "title": "Matching",
          "src": "pages/matching.html",
          "interactions": [{ "id": "match1", "type": "matching" }]
        },
        {
          "id": "p-categorize",
          "title": "Categorize",
          "src": "pages/categorize.html",
          "interactions": [{ "id": "cat1", "type": "matching" }]
        }
      ]
    }
  ]
}
